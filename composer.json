{
    "name": "grnspc/essentials",
    "description": "Just better defaults for your Laravel projects.",
    "keywords": ["php", "laravel", "package", "essentials", "laravel-essentials"],
    "license": "MIT",
    "authors": [
        {
            "name": "GRNSPC",
            "email": "grnspc.dev@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3.0",
        "laravel/framework": "^13.15"
    },
    "require-dev": {
        "laravel/pint": "^1.29.1",
        "laravel/pao": "^1.1.1",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7.3",
        "pestphp/pest-plugin-type-coverage": "^4.0.4",
        "phpstan/phpstan": "^2.2.2",
        "rector/rector": "^2.4.5",
        "symfony/var-dumper": "^8.1.0"
    },
    "autoload": {
        "psr-4": {
            "Grnspc\\Essentials\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "refactor": "rector",
        "lint": "pint --parallel",
        "test:refactor": "rector --dry-run",
        "test:lint": "pint --parallel --test",
        "test:types": "phpstan analyse --ansi",
        "test:unit": "XDEBUG_MODE=\"coverage\" pest --colors=always --coverage --parallel",
        "test": [
            "@test:refactor",
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Grnspc\\Essentials\\EssentialsServiceProvider"
            ]
        }
    }
}
